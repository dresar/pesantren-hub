{
  "name": "pesantren-hub-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "esbuild src/entry-cpanel.ts --bundle --platform=node --target=node22 --outfile=index.js --external:pg --external:ws --external:bcryptjs --external:cloudinary && node scripts/prepare-2026.js",
    "build:cpanel": "esbuild src/entry-cpanel.ts --bundle --platform=node --target=node22 --outfile=app.cjs --external:pg --external:ws --external:bcryptjs --external:cloudinary && node scripts/create-bridge.js",
    "db:generate": "drizzle-kit generate:pg",
    "db:push": "drizzle-kit push:pg"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.2.0",
    "@neondatabase/serverless": "^1.0.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.29.0",
    "drizzle-zod": "^0.5.1",
    "hono": "^4.0.0",
    "imagekit": "^6.0.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.18.0",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^3.25.76",
    "@hono/node-server": "^1.10.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.16.5",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.20.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
